# ─────────────────────────────────────────────────────────────────────────────
# BD Platform - Production Environment Variables
# Copy this file to .env in your cPanel app directory and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Port (cPanel / Phusion Passenger sets this automatically — leave as 3000)
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:3306/YOUR_DB_NAME

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Use a long random string (32+ characters)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# ── Frontend API URL ─────────────────────────────────────────────────────────
# Set to your actual domain — must end with /api
NEXT_PUBLIC_API_URL=https://business-development.erpsolution26.com/api

# ── CORS ─────────────────────────────────────────────────────────────────────
# Same as your domain (the frontend origin)
FRONTEND_URL=https://business-development.erpsolution26.com
