generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum Sector {
  DEFENCE
  MEDICAL
  AUTOMOTIVE
  CLIMATE_CONTROL
  ELECTRONICS
  TECHNOLOGY
  OTHER
}

enum BusinessStage {
  IDEA
  EXPLORING
  PROPOSAL
  NEGOTIATION
  ACTIVE
  ON_HOLD
  WON
  LOST
}

enum ProductNature {
  ELECTRONIC
  MECHANICAL
  ELECTRO_MECHANICAL
  SOFTWARE
  SYSTEM_INTEGRATION
  HYBRID
}

enum ProjectType {
  PROJECT
  PROGRAM
  PRODUCT
  SOLUTION
  POC
  PILOT
}

enum ProjectStatus {
  CONCEPT
  PROPOSAL
  DEVELOPMENT
  TESTING
  DEPLOYED
  ON_HOLD
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  REQUIREMENT
}

enum LeadSource {
  REFERRAL
  EXHIBITION
  WEBSITE
  COLD_CALL
  RFP_PORTAL
  GOVERNMENT_TENDER
  PARTNER
  SOCIAL_MEDIA
  OTHER
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  VIDEO_CALL
  DEMO
  PRESENTATION
  OTHER
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  avatar       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  businesses Business[]
  activities ActivityLog[]
  leads      Lead[]

  @@map("users")
}

// ─── BUSINESSES ───────────────────────────────────────────────────────────────

model Business {
  id             String        @id @default(cuid())
  name           String
  description    String?       @db.Text
  sector         Sector
  category       String        // Sector-specific sub-category (e.g. RADAR, DRONE, RESPIRATORY)
  productNature  ProductNature @default(ELECTRONIC) @map("product_nature")
  stage          BusinessStage @default(IDEA)
  score          Int           @default(0) // 0-100 opportunity score
  priority       String        @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  targetCustomer String?       @map("target_customer")
  targetMarket   String?       @map("target_market")
  estimatedValue Decimal?      @db.Decimal(15, 2) @map("estimated_value")
  currency       String        @default("INR")
  startDate      DateTime?     @map("start_date")
  targetDate     DateTime?     @map("target_date")
  ownerId        String?       @map("owner_id")
  owner          User?         @relation(fields: [ownerId], references: [id])
  parentId       String?       @map("parent_id")
  parent         Business?     @relation("SubBusinesses", fields: [parentId], references: [id])
  children       Business[]    @relation("SubBusinesses")
  notes          String?       @db.Text
  tags           Json          @default("[]")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  projects          Project[]
  feedbacks         CustomerFeedback[]
  milestones        Milestone[]
  activities        ActivityLog[]
  attachments       Attachment[]
  convertedFromLead Lead?

  @@map("businesses")
}

// ─── ATTACHMENTS ──────────────────────────────────────────────────────────────

model Attachment {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  filename    String
  originalName String  @map("original_name")
  mimeType    String   @map("mime_type")
  size        Int
  description String?  @db.Text
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("attachments")
}

// ─── PROJECTS / PRODUCTS / SOLUTIONS ─────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  name            String
  description     String?       @db.Text
  businessId      String        @map("business_id")
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type            ProjectType   @default(PROJECT)
  productNature   ProductNature @default(ELECTRONIC) @map("product_nature")
  status          ProjectStatus @default(CONCEPT)
  score           Int           @default(0)
  progress        Int           @default(0) // 0-100 percent
  startDate       DateTime?     @map("start_date")
  endDate         DateTime?     @map("end_date")
  budget          Decimal?      @db.Decimal(15, 2)
  customer        String?
  customerContact String?       @map("customer_contact")
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  feedbacks  CustomerFeedback[]
  milestones Milestone[]

  @@map("projects")
}

// ─── CUSTOMER FEEDBACK ────────────────────────────────────────────────────────

model CustomerFeedback {
  id           String            @id @default(cuid())
  businessId   String?           @map("business_id")
  business     Business?         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  projectId    String?           @map("project_id")
  project      Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customerName String            @map("customer_name")
  customerOrg  String?           @map("customer_org")
  sentiment    FeedbackSentiment @default(NEUTRAL)
  rating       Int?              // 1-5
  feedback     String            @db.Text
  date         DateTime          @default(now())
  createdAt    DateTime          @default(now()) @map("created_at")

  @@map("customer_feedbacks")
}

// ─── MILESTONES ───────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  businessId  String?         @map("business_id")
  business    Business?       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  projectId   String?         @map("project_id")
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime        @map("due_date")
  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("milestones")
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String    @id @default(cuid())
  businessId  String?   @map("business_id")
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id])
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("activity_logs")
}

// ─── CRM: LEADS ──────────────────────────────────────────────────────────────

model Lead {
  id                  String          @id @default(cuid())
  title               String
  description         String?         @db.Text
  sector              Sector
  category            String
  source              LeadSource      @default(OTHER)
  temperature         LeadTemperature @default(COLD)
  stage               String          // sector-specific, validated in app layer
  estimatedValue      Decimal?        @db.Decimal(15, 2) @map("estimated_value")
  currency            String          @default("INR")
  priority            String          @default("MEDIUM")
  companyName         String?         @map("company_name")
  expectedCloseDate   DateTime?       @map("expected_close_date")
  ownerId             String?         @map("owner_id")
  owner               User?           @relation(fields: [ownerId], references: [id])
  convertedBusinessId String?         @unique @map("converted_business_id")
  convertedBusiness   Business?       @relation(fields: [convertedBusinessId], references: [id])
  notes               String?         @db.Text
  tags                Json            @default("[]")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  contacts     LeadContact[]
  interactions Interaction[]

  @@map("leads")
}

// ─── CRM: CONTACTS ───────────────────────────────────────────────────────────

model Contact {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  designation  String?
  organization String?
  department   String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  leads        LeadContact[]
  interactions Interaction[]

  @@map("contacts")
}

// ─── CRM: LEAD-CONTACT JOIN ──────────────────────────────────────────────────

model LeadContact {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId String   @map("contact_id")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role      String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([leadId, contactId])
  @@map("lead_contacts")
}

// ─── CRM: INTERACTIONS ───────────────────────────────────────────────────────

model Interaction {
  id             String          @id @default(cuid())
  leadId         String?         @map("lead_id")
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId      String?         @map("contact_id")
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  type           InteractionType @default(OTHER)
  subject        String
  description    String?         @db.Text
  date           DateTime        @default(now())
  duration       Int?
  outcome        String?
  nextAction     String?         @map("next_action")
  nextActionDate DateTime?       @map("next_action_date")
  userId         String?         @map("user_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@map("interactions")
}
